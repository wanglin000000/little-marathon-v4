# 阿里云OSS静态网站托管配置
# 上传以下_headers文件到OSS根目录

/*
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/*.js
  Cache-Control: no-cache
  Pragma: no-cache

/*.css
  Cache-Control: no-cache
  Pragma: no-cache
